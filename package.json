{
  "name": "vibe-cli",
  "module": "src/cli/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "chat": "bun run --watch src/cli/index.ts",
    "build:binary": "bun run scripts/build-binary.ts",
    "format": "biome format --write src test scripts README.md package.json biome.json",
    "typecheck": "tsc --noEmit ",
    "sanity": "bun run format && bun run typecheck && bun test",
    "config:init": "bun run src/cli/index.ts -- init"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "agent-tools-ts": "github:ishibashi-futos/agent-tools-ts#v0.6.0",
    "openai": "^6.25.0",
    "terminal-ui-kit": "github:ishibashi-futos/terminal-ui-kit#v0.3.0"
  }
}
